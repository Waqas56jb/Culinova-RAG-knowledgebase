# ---- CULINOVA EOS server config ----
PORT=4400

# Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# OpenAI (extraction + embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EXTRACTION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB (vector search). Start a local server:  chroma run --path ./chroma-data
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=ceks_knowledge

# CORS (comma-separated origins for admin + client apps)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
