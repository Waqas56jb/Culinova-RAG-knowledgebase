# ============================================================================
# CULINOVA EOS — server configuration.  Copy to .env and fill in.
# The real .env is gitignored; never commit secrets.
# ============================================================================
PORT=4400
NODE_ENV=development

# ── AUTH (required) ──────────────────────────────────────────────────────────
# A long random string. There is NO default: without it every sign-in is rejected, and in
# production the server refuses to boot. Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=
AUTH_ACCESS_TTL=12h
AUTH_REFRESH_DAYS=30

# ── Database ─────────────────────────────────────────────────────────────────
# Direct Postgres connection string — used ONLY by the migration runner (npm run migrate).
# Supabase → Project Settings → Database → Connection string (session pooler).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ── Supabase (the app's data client) ─────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── OpenAI (extraction + embeddings + assistant) ─────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EXTRACTION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=2

# ── ChromaDB (optional vector search). Local:  chroma run --path ./chroma-data ─
# Leave CHROMA_URL unset in production to fall back to text search.
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=ceks_knowledge

# ── CORS ─────────────────────────────────────────────────────────────────────
# Exact browser origins of the admin + client apps (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Set to true ONLY if you want to allow any *.vercel.app preview origin (off by default).
CORS_ALLOW_VERCEL=false

# ── Rate limits (per IP; a speed bump, not a distributed limiter) ────────────
RATE_LIMIT_PER_MIN=300
RATE_LIMIT_INGEST_PER_15MIN=60
RATE_LIMIT_AI_PER_5MIN=40
RATE_LIMIT_AUTH_PER_15MIN=50

# ── Upload / parsing limits ──────────────────────────────────────────────────
UPLOAD_MAX_FILE_MB=50
UPLOAD_MAX_FILES=400
PDF_MAX_CHARS=60000
PAGE_SIZE_DEFAULT=50
PAGE_SIZE_MAX=200
